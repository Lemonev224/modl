            const gained = items.reduce((a, b) => a + b.gained, 0)
            const converted = items.reduce((a, b) => a + b.converted, 0)
            const rate = gained > 0 ? ((converted / gained) * 100).toFixed(0) : 0
            return (
              <div key={type} style={{ marginBottom: 14 }}>
