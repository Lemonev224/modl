                  <span style={{ color: c.gold, fontSize: 14 }}>→</span>
                </div>
              </a>
            ))}
          </div>
        </div>

        {/* Earnings breakdown */}
        <div style={s.card}>
          <p style={s.sectionTitle}>Earnings breakdown</p>
          {[
            { label: 'Subscriptions', value: '£1,620', pct: 57 },
            { label: 'Pay-per-view', value: '£840', pct: 30 },
            { label: 'Tips', value: '£380', pct: 13 },
