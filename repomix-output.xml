        </div>

        {/* Conversion by type */}
        <div style={s.card}>
          <p style={{ fontFamily: 'var(--font-display)', fontSize: 18, fontWeight: 400, color: c.black, marginBottom: 16 }}>Conversion by type</p>
          {['Shoutout', 'Reddit', 'Collab'].map(type => {
